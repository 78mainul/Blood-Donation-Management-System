<AnchorPane id="AnchorPane" prefHeight="384.0" prefWidth="569.0" xmlns="http://javafx.com/javafx/20.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="bloodforlife.FXMLDocumentController">
