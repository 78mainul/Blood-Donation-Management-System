<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>


<AnchorPane id="AnchorPane" prefHeight="400.0" prefWidth="600.0" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/20.0.1" fx:controller="bloodforlife.SearchController">
   <children>
      <TextField fx:id="bloodGroupField" layoutX="66.0" layoutY="71.0" promptText="Enter Blood group" />
      <Button layoutX="71.0" layoutY="108.0" mnemonicParsing="false" onAction="#handleSearch" text="Search" />
      <TableView fx:id="tableView" layoutX="277.0" layoutY="117.0" prefHeight="200.0" prefWidth="224.0">
        <columns>
          <TableColumn fx:id="nameCol" prefWidth="75.0" text="Name" />
          <TableColumn fx:id="emailCol" prefWidth="75.0" text="Email" />
            <TableColumn fx:id="contactCol" prefWidth="75.0" text="Contact" />
        </columns>
      </TableView>
   </children>
</AnchorPane>
